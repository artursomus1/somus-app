{
  "name": "somus-app",
  "version": "2.0.0",
  "description": "Somus Capital - Plataforma de Automação Financeira",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --config electron-builder.yml",
    "electron:build:win": "vite build && electron-builder --win --config electron-builder.yml",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4",
    "recharts": "^2.12.7",
    "@tanstack/react-table": "^8.20.1",
    "react-hook-form": "^7.52.1",
    "zod": "^3.23.8",
    "@hookform/resolvers": "^3.9.0",
    "pptxgenjs": "^3.12.0",
    "pdfmake": "^0.2.10",
    "xlsx": "^0.18.5",
    "lucide-react": "^0.427.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "electron-updater": "^6.2.1",
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/pdfmake": "^0.2.9",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "tailwindcss": "^3.4.7",
    "postcss": "^8.4.40",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.8.0",
    "vitest": "^2.0.5",
    "@testing-library/react": "^16.0.0"
  }
}
